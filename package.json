{
  "name": "budget-optimizer",
  "version": "2.8.0",
  "description": "Secure Budget Optimizer - A desktop app for managing income and optimizing bill payments",
  "author": "Michael Davis",
  "packageManager": "pnpm@9.15.9",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "build:vite": "vite build",
    "analyze": "ANALYZE=1 vite build",
    "verify:csp": "node scripts/verify-production-csp.cjs",
    "preview": "vite preview",
    "electron:dev": "node scripts/sync-app-icon.cjs && concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:reinstall": "node scripts/fix-electron-install.cjs",
    "postinstall": "electron-builder install-app-deps && node scripts/rebuild-electron-native.cjs && node scripts/sync-better-sqlite3-native.cjs",
    "reset-local-data": "bash scripts/reset-local-data.sh",
    "electron:build": "node scripts/sync-app-icon.cjs && pnpm run build:vite && node scripts/rebuild-electron-native.cjs && node scripts/sync-better-sqlite3-native.cjs && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder && node scripts/verify-packaged-app.cjs",
    "electron:build:ci": "node scripts/sync-app-icon.cjs && pnpm run build:vite && node scripts/rebuild-electron-native.cjs && node scripts/sync-better-sqlite3-native.cjs && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --publish never && node scripts/verify-packaged-app.cjs",
    "sync:icon": "node scripts/sync-app-icon.cjs",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "typecheck:electron": "tsc -p tsconfig.node.json --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:coverage:check": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:touchpoints": "node scripts/e2e-touchpoints.cjs",
    "audit:dev": "node scripts/audit-dev.cjs",
    "sbom": "pnpm dlx @cyclonedx/cdxgen@^11 --type pnpm --output sbom.json --no-recurse",
    "prepush": "bash scripts/pre-push-quality.sh",
    "prepare": "husky"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "clsx": "^2.1.0",
    "date-fns": "^4.4.0",
    "keytar": "^7.9.0",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@playwright/test": "^1.61.0",
    "@resvg/resvg-js": "^2.6.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@vitejs/plugin-react": "^6.0.0",
    "@vitest/coverage-v8": "^4.1.8",
    "autoprefixer": "^10.5.0",
    "concurrently": "^10.0.3",
    "electron": "^33.4.11",
    "electron-builder": "^26.15.3",
    "electron-playwright-helpers": "^2.1.0",
    "eslint": "^8.56.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "exceljs": "^4.4.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "postcss": "^8.4.35",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^3.4.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-electron": "^1.0.4",
    "vite-plugin-electron-renderer": "^1.0.0",
    "vitest": "^4.1.8",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.budgetoptimizer.app",
    "productName": "Budget Optimizer",
    "icon": "build/icon.png",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "npmRebuild": false,
    "mac": {
      "category": "public.app-category.finance",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
